# ── Supabase (backend) ──
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=seu_anon_key
SUPABASE_SERVICE_ROLE_KEY=seu_service_role_key

# ── OpenAI ──
OPENAI_API_KEY=sk-...

# ── Server (local dev) ──
PORT=3001
NODE_ENV=development

# ── Vercel Cron (produção) ──
# Gere um valor aleatório seguro para proteger o endpoint de cron
CRON_SECRET=gere-um-valor-seguro-aqui

# ── CORS (produção) ──
# URL do frontend em produção para habilitar CORS
CLIENT_URL=https://mercagro.vercel.app

# ── Client (Vite) - copiar para client/.env ──
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=seu_anon_key
# Em produção na Vercel, deixe vazio (frontend e API no mesmo domínio)
VITE_API_URL=http://localhost:3001
